<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Allgemeinwissen Quiz</title>
    <style>
        body {
            font-family: Arial;
            background: #0f172a;
            color: white;
            text-align: center;
            padding-top: 100px;
        }

        .box {
            background: rgba(255,255,255,0.1);
            padding: 40px;
            border-radius: 15px;
            display: inline-block;
        }

        button {
            display: block;
            margin: 10px auto;
            padding: 12px 25px;
            font-size: 16px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
        }

        button:hover {
            background: #facc15;
        }
    </style>
</head>
<body>

<div class="box">
    <h1>Allgemeinwissen</h1>

    <h2>Was ist die Hauptstadt von Frankreich?</h2>

    <button>Berlin</button>
    <button>Madrid</button>
    <button>Paris</button>
    <button>Rom</button>

    <br>
    <a href="/kategorien">Zurück</a>
</div>

</body>
</html>